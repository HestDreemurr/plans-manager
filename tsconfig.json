{
  "compilerOptions": {
    "target": "es2024",
    "module": "es6",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "#types": ["./src/@types/types.d"]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
